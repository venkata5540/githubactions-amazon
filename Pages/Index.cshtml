@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Amazon.in - Mobiles</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background-color: #eaeded;
            color: #111;
        }

        /* Header / Navbar */
        .navbar {
            background-color: #131921;
            color: #fff;
            display: flex;
            align-items: center;
            padding: 8px 16px;
            gap: 16px;
            flex-wrap: wrap;
        }

        .nav-logo {
            font-weight: bold;
            font-size: 20px;
            letter-spacing: 0.5px;
        }

            .nav-logo span {
                color: #ff9900;
            }

        .nav-location {
            font-size: 12px;
            line-height: 1.2;
        }

        .nav-location-title {
            color: #ccc;
        }

        .nav-search {
            flex: 1;
            display: flex;
            max-width: 600px;
        }

            .nav-search select {
                padding: 8px;
                border: none;
                outline: none;
                background-color: #f3f3f3;
                font-size: 13px;
            }

            .nav-search input {
                flex: 1;
                padding: 8px;
                border: none;
                outline: none;
                font-size: 14px;
            }

            .nav-search button {
                border: none;
                padding: 0 14px;
                cursor: pointer;
                font-size: 14px;
                background-color: #febd69;
            }

        .nav-account,
        .nav-orders,
        .nav-cart {
            font-size: 12px;
            cursor: pointer;
            white-space: nowrap;
        }

            .nav-cart strong {
                font-size: 16px;
            }

        .nav-secondary {
            background-color: #232f3e;
            color: #fff;
            padding: 8px 16px;
            font-size: 13px;
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

            .nav-secondary span {
                cursor: pointer;
                white-space: nowrap;
            }

                .nav-secondary span:hover {
                    text-decoration: underline;
                }

        /* Page layout */
        .page {
            display: flex;
            padding: 16px;
            gap: 16px;
        }

        /* Sidebar filters */
        .sidebar {
            width: 240px;
            background-color: #fff;
            padding: 12px;
            border-radius: 4px;
        }

            .sidebar h3 {
                font-size: 16px;
                margin-bottom: 8px;
            }

        .sidebar-section {
            margin-bottom: 16px;
            font-size: 13px;
        }

            .sidebar-section h4 {
                font-size: 13px;
                margin-bottom: 6px;
            }

            .sidebar-section label {
                display: block;
                margin-bottom: 4px;
                cursor: pointer;
            }

        /* Main content */
        .main-content {
            flex: 1;
        }

        .breadcrumb {
            font-size: 12px;
            margin-bottom: 8px;
            color: #555;
        }

        .main-title {
            font-size: 20px;
            margin-bottom: 4px;
        }

        .results-info {
            font-size: 12px;
            margin-bottom: 12px;
            color: #555;
        }

        /* Products grid */
        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 12px;
        }

        .product-card {
            background-color: #fff;
            padding: 12px;
            border-radius: 4px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 260px;
        }

        .product-top {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 8px;
        }

        .product-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background-color: #f3f3f3;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            margin-bottom: 4px;
        }

        .product-title {
            font-size: 14px;
            font-weight: 600;
        }

        .product-rating {
            font-size: 12px;
            color: #007185;
        }

        .product-price {
            margin-top: 8px;
            font-size: 18px;
            font-weight: 700;
        }

            .product-price span {
                font-size: 12px;
                font-weight: 400;
            }

        .product-offer {
            font-size: 12px;
            color: #b12704;
            margin-top: 4px;
        }

        .product-actions {
            margin-top: 10px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .btn-primary {
            padding: 6px 10px;
            border: 1px solid #f0c14b;
            background-color: #ffd814;
            border-radius: 4px;
            cursor: pointer;
            font-size: 13px;
        }

            .btn-primary:hover {
                background-color: #f7ca00;
            }

        .btn-secondary {
            padding: 6px 10px;
            border: 1px solid #d5d9d9;
            background-color: #fff;
            border-radius: 4px;
            cursor: pointer;
            font-size: 13px;
        }

            .btn-secondary:hover {
                background-color: #f3f3f3;
            }

        /* Footer */
        .footer {
            margin-top: 24px;
            background-color: #131921;
            color: #fff;
            text-align: center;
            padding: 12px;
            font-size: 12px;
        }

        /* Responsive */
    </style>
</head>
<body>
    <!-- Header -->
    <header>
        <div class="navbar">
            <div class="nav-logo">amazon<span>.in</span></div>

            <div class="nav-location">
                <div class="nav-location-title">Deliver to</div>
                <div>India</div>
            </div>

            <form class="nav-search">
                <select>
                    <option>All</option>
                    <option selected>Mobiles</option>
                    <option>Electronics</option>
                    <option>Accessories</option>
                </select>
                <input type="text" placeholder="Search Mobiles" />
                <button type="button">🔍</button>
            </form>

            <div class="nav-account">
                <div>Hello, Sign in</div>
                <strong>Account &amp; Lists</strong>
            </div>

            <div class="nav-orders">
                <div>Returns</div>
                <strong>&amp; Orders</strong>
            </div>

            <div class="nav-cart">
                <strong>🛒</strong> Cart
            </div>
        </div>

        <div class="nav-secondary">
            <span>All</span>
            <span>Mobiles</span>
            <span>Best Sellers</span>
            <span>Today's Deals</span>
            <span>Customer Service</span>
            <span>New Releases</span>
        </div>
    </header>

    <!-- Main -->
    <main class="page">
        <!-- Sidebar Filters -->
        <aside class="sidebar">
            <h3>Filters</h3>

            <div class="sidebar-section">
                <h4>Brand</h4>
                <label><input type="checkbox" /> Samsung</label>
                <label><input type="checkbox" /> Apple</label>
                <label><input type="checkbox" /> OnePlus</label>
                <label><input type="checkbox" /> Redmi</label>
                <label><input type="checkbox" /> Realme</label>
            </div>

            <div class="sidebar-section">
                <h4>Price</h4>
                <label><input type="radio" name="price" /> Under ₹10,000</label>
                <label><input type="radio" name="price" /> ₹10,000 - ₹20,000</label>
                <label><input type="radio" name="price" /> ₹20,000 - ₹30,000</label>
                <label><input type="radio" name="price" /> ₹30,000 - ₹50,000</label>
                <label><input type="radio" name="price" /> Above ₹50,000</label>
            </div>

            <div class="sidebar-section">
                <h4>Screen Size</h4>
                <label><input type="checkbox" /> 5" - 5.9"</label>
                <label><input type="checkbox" /> 6" - 6.5"</label>
                <label><input type="checkbox" /> Above 6.5"</label>
            </div>

            <div class="sidebar-section">
                <h4>Customer Rating</h4>
                <label>⭐⭐⭐⭐ &amp; up</label>
                <label>⭐⭐⭐ &amp; up</label>
            </div>
        </aside>

        <!-- Main Content -->
        <section class="main-content">
            <div class="breadcrumb">Mobiles &gt; Smartphones</div>
            <h1 class="main-title">Mobiles</h1>
            <div class="results-info">Showing top picks for you</div>

            <div class="products-grid">
                <!-- Product 1 -->
                <article class="product-card">
                    <div class="product-top">
                        <div class="product-icon">📱</div>
                        <div class="product-title">Samsung Galaxy S24 5G (128GB, 8GB RAM)</div>
                        <div class="product-rating">⭐⭐⭐⭐ 4.3 | 3,242 ratings</div>
                        <div class="product-price"><span>₹</span>74,999</div>
                        <div class="product-offer">Flat ₹5,000 bank offer</div>
                    </div>
                    <div class="product-actions">
                        <button class="btn-primary">Add to Cart</button>
                        <button class="btn-secondary">Buy Now</button>
                    </div>
                </article>

                <!-- Product 2 -->
                <article class="product-card">
                    <div class="product-top">
                        <div class="product-icon">📲</div>
                        <div class="product-title">Apple iPhone 15 (128GB)</div>
                        <div class="product-rating">⭐⭐⭐⭐⭐ 4.7 | 8,540 ratings</div>
                        <div class="product-price"><span>₹</span>79,900</div>
                        <div class="product-offer">No Cost EMI available</div>
                    </div>
                    <div class="product-actions">
                        <button class="btn-primary">Add to Cart</button>
                        <button class="btn-secondary">View Details</button>
                    </div>
                </article>

                <!-- Product 3 -->
                <article class="product-card">
                    <div class="product-top">
                        <div class="product-icon">📞</div>
                        <div class="product-title">OnePlus 12R 5G (256GB, 12GB RAM)</div>
                        <div class="product-rating">⭐⭐⭐⭐ 4.5 | 12,102 ratings</div>
                        <div class="product-price"><span>₹</span>42,999</div>
                        <div class="product-offer">Exchange offer up to ₹5,000</div>
                    </div>
                    <div class="product-actions">
                        <button class="btn-primary">Add to Cart</button>
                        <button class="btn-secondary">Add to Wish List</button>
                    </div>
                </article>

                <!-- Product 4 -->
                <article class="product-card">
                    <div class="product-top">
                        <div class="product-icon">📳</div>
                        <div class="product-title">Redmi Note 13 Pro 5G (8GB, 256GB)</div>
                        <div class="product-rating">⭐⭐⭐⭐ 4.2 | 5,001 ratings</div>
                        <div class="product-price"><span>₹</span>24,999</div>
                        <div class="product-offer">Limited time deal</div>
                    </div>
                    <div class="product-actions">
                        <button class="btn-primary">Add to Cart</button>
                        <button class="btn-secondary">Buy Now</button>
                    </div>
                </article>

                <!-- Product 5 -->
                <article class="product-card">
                    <div class="product-top">
                        <div class="product-icon">📶</div>
                        <div class="product-title">Realme Narzo 70 5G (6GB, 128GB)</div>
                        <div class="product-rating">⭐⭐⭐ 3.9 | 1,230 ratings</div>
                        <div class="product-price"><span>₹</span>14,999</div>
                        <div class="product-offer">Save extra with coupon</div>
                    </div>
                    <div class="product-actions">
                        <button class="btn-primary">Add to Cart</button>
                        <button class="btn-secondary">View Details</button>
                    </div>
                </article>

                <!-- Product 6 -->
                <article class="product-card">
                    <div class="product-top">
                        <div class="product-icon">📡</div>
                        <div class="product-title">Motorola Edge 50 Fusion (8GB, 256GB)</div>
                        <div class="product-rating">⭐⭐⭐⭐ 4.1 | 3,020 ratings</div>
                        <div class="product-price"><span>₹</span>29,999</div>
                        <div class="product-offer">Extra ₹3,000 off on exchange</div>
                    </div>
                    <div class="product-actions">
                        <button class="btn-primary">Add to Cart</button>
                        <button class="btn-secondary">Buy Now</button>
                    </div>
                </article>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="footer">
        © 2025, Amazon Clone Mobiles Page (Sample UI)
    </footer>
</body>
</html>
